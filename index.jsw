import React, { useState, useEffect } from 'react';
import { 
  LayoutDashboard, Briefcase, CheckSquare, Users, Plus, 
  Clock, CheckCircle2, Circle, Link as LinkIcon, LogOut, UserCircle, Sparkles
} from 'lucide-react';

// --- FIREBASE IMPORTS (Our Cloud Database & Auth) ---
import { initializeApp } from 'firebase/app';
import { getAuth, signInWithCustomToken, signInAnonymously, onAuthStateChanged, signOut } from 'firebase/auth';
import { getFirestore, collection, doc, setDoc, onSnapshot, deleteDoc, updateDoc } from 'firebase/firestore';

// 1. SETUP FIREBASE
// We securely connect to the database using the environment's configuration
const firebaseConfig = JSON.parse(typeof __firebase_config !== 'undefined' ? __firebase_config : '{}');
const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);
const appId = typeof __app_id !== 'undefined' ? __app_id : 'default-app-id';

// Helper to get a random color for user profiles
const colors = ['bg-blue-500', 'bg-emerald-500', 'bg-purple-500', 'bg-pink-500', 'bg-orange-500', 'bg-teal-500'];
const getRandomColor = () => colors[Math.floor(Math.random() * colors.length)];

// --- GEMINI API CONFIGURATION ---
const apiKey = ""; // Injected by the environment securely

const callGemini = async (prompt, schema = null) => {
  const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
  const payload = {
    contents: [{ parts: [{ text: prompt }] }],
  };
  
  // If we expect JSON, we enforce a strict schema output
  if (schema) {
    payload.generationConfig = {
      responseMimeType: "application/json",
      responseSchema: schema
    };
  }

  // Exponential backoff to handle temporary API errors
  const delays = [1000, 2000, 4000, 8000, 16000];
  for (let i = 0; i < delays.length; i++) {
    try {
      const response = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const data = await response.json();
      return data.candidates[0].content.parts[0].text;
    } catch (err) {
      if (i === delays.length - 1) throw err;
      await new Promise(resolve => setTimeout(resolve, delays[i]));
    }
  }
};

export default function App() {
  // --- STATE MANAGEMENT ---
  const [user, setUser] = useState(null); // The logged-in user
  const [isAuthLoading, setIsAuthLoading] = useState(true);
  
  // Cloud Data states
  const [company, setCompany] = useState(undefined); // undefined means still loading
  const [team, setTeam] = useState([]);
  const [projects, setProjects] = useState([]);
  const [tasks, setTasks] = useState([]);

  // UI States
  const [activeTab, setActiveTab] = useState('dashboard');
  const [isModalOpen, setIsModalOpen] = useState(false);
  const [newTask, setNewTask] = useState({ title: '', projectId: '', assigneeId: '', status: 'todo' });
  const [copyMessage, setCopyMessage] = useState('');

  // AI Feature States
  const [isGeneratingTasks, setIsGeneratingTasks] = useState(null);
  const [aiReport, setAiReport] = useState('');
  const [isGeneratingReport, setIsGeneratingReport] = useState(false);

  // --- STEP 1: AUTHENTICATION (The Bouncer) ---
  useEffect(() => {
    const initAuth = async () => {
      try {
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          await signInWithCustomToken(auth, __initial_auth_token);
        } else {
          await signInAnonymously(auth);
        }
      } catch (error) {
        console.error("Auth error:", error);
      }
    };
    initAuth();

    // Listen for login/logout changes
    const unsubscribe = onAuthStateChanged(auth, (currentUser) => {
      setUser(currentUser);
      setIsAuthLoading(false);
    });
    return () => unsubscribe();
  }, []);

  // --- STEP 2: CLOUD DATA LISTENERS (The Walkie-Talkies) ---
  useEffect(() => {
    // If nobody is logged in, don't try to fetch data
    if (!user) return;

    // 1. Listen for the Company Info
    const companyRef = doc(db, 'artifacts', appId, 'public', 'data', 'config', 'company');
    const unsubCompany = onSnapshot(companyRef, (docSnap) => {
      if (docSnap.exists()) {
        setCompany(docSnap.data());
      } else {
        setCompany(null); // null means no company exists yet
      }
    });

    // 2. Listen for Team Members
    const teamRef = collection(db, 'artifacts', appId, 'public', 'data', 'team');
    const unsubTeam = onSnapshot(teamRef, (snap) => {
      setTeam(snap.docs.map(d => ({ id: d.id, ...d.data() })));
    });

    // 3. Listen for Projects
    const projectsRef = collection(db, 'artifacts', appId, 'public', 'data', 'projects');
    const unsubProjects = onSnapshot(projectsRef, (snap) => {
      setProjects(snap.docs.map(d => ({ id: d.id, ...d.data() })));
    });

    // 4. Listen for Tasks
    const tasksRef = collection(db, 'artifacts', appId, 'public', 'data', 'tasks');
    const unsubTasks = onSnapshot(tasksRef, (snap) => {
      setTasks(snap.docs.map(d => ({ id: d.id, ...d.data() })));
    });

    // Cleanup listeners when component closes
    return () => {
      unsubCompany();
      unsubTeam();
      unsubProjects();
      unsubTasks();
    };
  }, [user]); // We re-run this if the 'user' changes


  // --- HELPER FUNCTIONS FOR CLOUD DATA ---

  const handleCreateCompany = async (e) => {
    e.preventDefault();
    const companyName = e.target.companyName.value;
    const myName = e.target.userName.value;
    const myInitials = myName.split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase();

    // 1. Save Company
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'config', 'company'), {
      name: companyName,
      adminId: user.uid,
      createdAt: new Date().toISOString()
    });

    // 2. Save Myself as the first team member (Admin)
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'team', user.uid), {
      name: myName,
      role: 'CEO / Founder',
      systemRole: 'Admin', // Hierarchy: Admin can do everything
      initials: myInitials,
      color: getRandomColor()
    });

    // 3. Add a sample project so it's not empty
    const projId = 'proj_' + Date.now();
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'projects', projId), {
      name: 'First Internal Project',
      client: companyName,
      deadline: '2026-12-31',
      status: 'Active'
    });
  };

  const handleJoinCompany = async (e) => {
    e.preventDefault();
    const myName = e.target.userName.value;
    const myJobTitle = e.target.jobTitle.value;
    const myInitials = myName.split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase();

    // Save myself to the team as a Member
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'team', user.uid), {
      name: myName,
      role: myJobTitle,
      systemRole: 'Member', // Hierarchy: Standard employee
      initials: myInitials,
      color: getRandomColor()
    });
  };

  const handleAddTask = async (e) => {
    e.preventDefault();
    const taskId = 'task_' + Date.now();
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'tasks', taskId), {
      title: newTask.title,
      projectId: newTask.projectId,
      assigneeId: newTask.assigneeId,
      status: 'todo',
      createdAt: new Date().toISOString()
    });
    setIsModalOpen(false);
    setNewTask({ title: '', projectId: '', assigneeId: '', status: 'todo' });
  };

  const updateTaskStatus = async (taskId, newStatus) => {
    await updateDoc(doc(db, 'artifacts', appId, 'public', 'data', 'tasks', taskId), {
      status: newStatus
    });
  };

  const deleteTask = async (taskId) => {
    // Only Admins or the person assigned should ideally delete, but we'll enforce UI level check
    await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', 'tasks', taskId));
  };

  const copyInviteLink = () => {
    // In our environment, sharing the current URL shares the app instance
    const url = window.location.href;
    navigator.clipboard.writeText(url).then(() => {
      setCopyMessage('Link Copied!');
      setTimeout(() => setCopyMessage(''), 2000);
    }).catch(() => {
      // Fallback for older browsers or iframe restrictions
      const textArea = document.createElement("textarea");
      textArea.value = url;
      document.body.appendChild(textArea);
      textArea.select();
      document.execCommand("copy");
      document.body.removeChild(textArea);
      setCopyMessage('Link Copied!');
      setTimeout(() => setCopyMessage(''), 2000);
    });
  };

  // --- AI HELPER FUNCTIONS ---

  const generateTasksForProject = async (projectId, projectName) => {
    setIsGeneratingTasks(projectId);
    try {
      // We pass the team members and their roles to the AI so it knows who to assign tasks to
      const teamContext = team.map(t => ({ id: t.id, role: t.role, name: t.name }));
      const prompt = `You are an AI Project Manager. I have a project called "${projectName}".
      My team members are: ${JSON.stringify(teamContext)}.
      Break down this project into 3 to 4 logical starting tasks. Look at the team members' job titles/roles and accurately assign each task to the most appropriate person.`;

      // We enforce a strict JSON array output 
      const response = await callGemini(prompt, {
        type: "ARRAY",
        items: {
          type: "OBJECT",
          properties: {
            title: { type: "STRING" },
            assigneeId: { type: "STRING" }
          },
          required: ["title", "assigneeId"]
        }
      });

      const newTasks = JSON.parse(response);
      for (const task of newTasks) {
        // Fallback to the current user if the AI hallucinates an ID
        const validAssignee = team.find(t => t.id === task.assigneeId) ? task.assigneeId : user.uid;
        const taskId = 'task_' + Date.now() + Math.random().toString(36).substring(7);
        await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'tasks', taskId), {
          title: task.title,
          projectId: projectId,
          assigneeId: validAssignee,
          status: 'todo',
          createdAt: new Date().toISOString()
        });
      }
    } catch (error) {
      console.error("AI Task Generation failed:", error);
    } finally {
      setIsGeneratingTasks(null);
    }
  };

  const generateStatusReport = async () => {
    setIsGeneratingReport(true);
    try {
      const taskSummary = tasks.map(t => `'${t.title}' is currently '${t.status}'`);
      const prompt = `You are an AI assistant helping a team manager. The team currently has the following task statuses: ${taskSummary.join(', ')}. Write a short 2-3 sentence encouraging status report summarizing our progress and highlighting what we need to focus on next. Don't use any markdown syntax, just return plain text.`;
      const report = await callGemini(prompt);
      setAiReport(report);
    } catch (err) {
      console.error("Report failed:", err);
      setAiReport("Failed to generate report. Please try again.");
    } finally {
      setIsGeneratingReport(false);
    }
  };

  // --- UI SCREENS (Views) ---

  // Loading Screen
  if (isAuthLoading || company === undefined) {
    return (
      <div className="h-screen bg-gray-950 flex items-center justify-center text-white">
        <div className="animate-pulse flex flex-col items-center">
          <div className="w-12 h-12 border-4 border-indigo-500 border-t-transparent rounded-full animate-spin mb-4"></div>
          <p className="text-gray-400">Connecting to Cloud Workspace...</p>
        </div>
      </div>
    );
  }

  // Current User Profile check
  const myProfile = team.find(t => t.id === user?.uid);

  // Onboarding Screen 1: Create or Join
  if (company === null) {
    return (
      <div className="h-screen bg-gray-950 flex items-center justify-center p-4">
        <div className="bg-gray-900 border border-gray-800 p-8 rounded-2xl w-full max-w-md shadow-2xl">
          <h2 className="text-2xl font-bold text-white mb-2">Welcome!</h2>
          <p className="text-gray-400 mb-6 text-sm">You are the first one here. Let's set up your company workspace.</p>
          <form onSubmit={handleCreateCompany} className="space-y-4">
            <div>
              <label className="block text-sm font-medium text-gray-400 mb-1">Company Name</label>
              <input name="companyName" required placeholder="e.g. ConfigMgr" className="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 text-white outline-none focus:border-indigo-500" />
            </div>
            <div>
              <label className="block text-sm font-medium text-gray-400 mb-1">Your Full Name</label>
              <input name="userName" required placeholder="e.g. Alex Sharma" className="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 text-white outline-none focus:border-indigo-500" />
            </div>
            <button type="submit" className="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-3 rounded-lg transition-colors mt-4">
              Create Workspace
            </button>
          </form>
        </div>
      </div>
    );
  }

  // Onboarding Screen 2: Join Existing Company
  if (company && !myProfile) {
    return (
      <div className="h-screen bg-gray-950 flex items-center justify-center p-4">
        <div className="bg-gray-900 border border-gray-800 p-8 rounded-2xl w-full max-w-md shadow-2xl">
          <div className="w-12 h-12 bg-indigo-500/20 text-indigo-400 rounded-xl flex items-center justify-center mb-4">
            <Users size={24} />
          </div>
          <h2 className="text-2xl font-bold text-white mb-2">Join {company.name}</h2>
          <p className="text-gray-400 mb-6 text-sm">You've been invited to join this workspace. Tell us who you are.</p>
          <form onSubmit={handleJoinCompany} className="space-y-4">
            <div>
              <label className="block text-sm font-medium text-gray-400 mb-1">Your Full Name</label>
              <input name="userName" required placeholder="e.g. Priya Patel" className="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 text-white outline-none focus:border-indigo-500" />
            </div>
            <div>
              <label className="block text-sm font-medium text-gray-400 mb-1">Your Role / Job Title</label>
              <input name="jobTitle" required placeholder="e.g. Web Developer" className="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 text-white outline-none focus:border-indigo-500" />
            </div>
            <button type="submit" className="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-3 rounded-lg transition-colors mt-4">
              Join Workspace
            </button>
          </form>
        </div>
      </div>
    );
  }

  // --- MAIN APP COMPONENTS ---

  const Sidebar = () => (
    <div className="w-64 bg-gray-900 border-r border-gray-800 flex flex-col h-screen fixed md:relative z-20">
      <div className="p-6">
        <h1 className="text-xl font-bold text-white flex items-center gap-3">
          <div className="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center shadow-lg shadow-indigo-500/30">
            <span className="text-sm">{company.name.charAt(0).toUpperCase()}</span>
          </div>
          <span className="truncate">{company.name}</span>
        </h1>
      </div>
      
      <div className="px-4 mb-6">
        <button onClick={copyInviteLink} className="w-full flex items-center justify-center gap-2 bg-gray-800 hover:bg-gray-700 text-gray-300 py-2 rounded-lg text-sm transition-colors border border-gray-700">
          <LinkIcon size={16} />
          {copyMessage || "Copy Invite Link"}
        </button>
      </div>

      <nav className="flex-1 px-4 space-y-1">
        {[
          { id: 'dashboard', name: 'Dashboard', icon: LayoutDashboard },
          { id: 'projects', name: 'Projects', icon: Briefcase },
          { id: 'tasks', name: 'Task Board', icon: CheckSquare },
          { id: 'team', name: 'Team Directory', icon: Users },
          { id: 'profile', name: 'My Profile', icon: UserCircle },
        ].map((item) => (
          <button
            key={item.id}
            onClick={() => setActiveTab(item.id)}
            className={`w-full flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-md transition-colors ${
              activeTab === item.id 
                ? 'bg-gray-800 text-white' 
                : 'text-gray-400 hover:bg-gray-800 hover:text-white'
            }`}
          >
            <item.icon size={18} />
            {item.name}
          </button>
        ))}
      </nav>
      
      <div className="p-4 border-t border-gray-800 bg-gray-900/50">
        <div className="flex items-center gap-3">
          <div className={`w-9 h-9 rounded-full ${myProfile.color} flex items-center justify-center text-sm font-bold text-white shadow-inner`}>
            {myProfile.initials}
          </div>
          <div className="flex-1 min-w-0">
            <p className="text-white font-medium text-sm truncate">{myProfile.name}</p>
            <p className="text-gray-400 text-xs truncate">{myProfile.systemRole}</p>
          </div>
        </div>
      </div>
    </div>
  );

  const DashboardView = () => (
    <div className="space-y-6">
      <h2 className="text-2xl font-semibold text-white">Welcome back, {myProfile.name.split(' ')[0]}!</h2>
      
      <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div className="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-sm">
          <p className="text-gray-400 text-sm font-medium">Active Projects</p>
          <p className="text-3xl font-bold text-white mt-2">{projects.length}</p>
        </div>
        <div className="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-sm">
          <p className="text-gray-400 text-sm font-medium">Company Tasks</p>
          <p className="text-3xl font-bold text-white mt-2">{tasks.length}</p>
        </div>
        <div className="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-sm">
          <p className="text-gray-400 text-sm font-medium">Team Size</p>
          <p className="text-3xl font-bold text-white mt-2">{team.length}</p>
        </div>
      </div>

      {/* AI Report Card */}
      <div className="bg-gradient-to-r from-indigo-900/40 to-purple-900/40 rounded-xl border border-indigo-500/30 p-6 mt-6 shadow-sm relative overflow-hidden">
        <div className="flex justify-between items-start mb-4">
          <h3 className="text-lg font-medium text-white flex items-center gap-2">
            <Sparkles className="text-indigo-400" size={20} />
            AI Team Insights
          </h3>
          <button
            onClick={generateStatusReport}
            disabled={isGeneratingReport}
            className="bg-indigo-600/20 text-indigo-300 hover:bg-indigo-600 hover:text-white px-3 py-1.5 rounded-lg text-sm font-medium transition-colors disabled:opacity-50 flex items-center gap-2 border border-indigo-500/30"
          >
            {isGeneratingReport ? 'Analyzing...' : '✨ Generate Insights'}
          </button>
        </div>
        <p className="text-indigo-100 text-sm leading-relaxed min-h-[40px]">
          {aiReport || "Click the button to get an AI-powered summary of your team's current task progress and next steps."}
        </p>
      </div>

      <div className="bg-gray-800 rounded-xl border border-gray-700 p-6 mt-6 shadow-sm">
        <h3 className="text-lg font-medium text-white mb-4">Your Open Tasks</h3>
        <div className="space-y-3">
          {tasks.filter(t => t.assigneeId === user.uid && t.status !== 'done').length === 0 ? (
            <p className="text-gray-400 text-sm">You have no pending tasks. Great job!</p>
          ) : (
            tasks.filter(t => t.assigneeId === user.uid && t.status !== 'done').map(task => (
              <div key={task.id} className="flex items-center justify-between bg-gray-900 p-3 rounded-lg border border-gray-800">
                <div>
                  <p className="text-white text-sm font-medium">{task.title}</p>
                  <p className="text-gray-500 text-xs">{projects.find(p => p.id === task.projectId)?.name || 'Unknown Project'}</p>
                </div>
                <span className="bg-yellow-500/10 text-yellow-400 text-xs px-2 py-1 rounded-full capitalize">
                  {task.status.replace('-', ' ')}
                </span>
              </div>
            ))
          )}
        </div>
      </div>
    </div>
  );

  const TaskBoard = () => {
    const columns = [
      { id: 'todo', title: 'To Do', icon: Circle, color: 'text-gray-400' },
      { id: 'in-progress', title: 'In Progress', icon: Clock, color: 'text-yellow-400' },
      { id: 'done', title: 'Done', icon: CheckCircle2, color: 'text-indigo-400' }
    ];

    return (
      <div className="h-full flex flex-col">
        <div className="flex justify-between items-center mb-6">
          <h2 className="text-2xl font-semibold text-white">Task Board</h2>
          <button 
            onClick={() => setIsModalOpen(true)}
            className="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-medium flex items-center gap-2 transition-colors shadow-lg shadow-indigo-500/20"
          >
            <Plus size={16} /> New Task
          </button>
        </div>

        <div className="grid grid-cols-1 md:grid-cols-3 gap-6 flex-1 items-start">
          {columns.map(col => (
            <div key={col.id} className="bg-gray-800/50 rounded-xl border border-gray-800 p-4 min-h-[500px]">
              <div className="flex items-center gap-2 mb-4">
                <col.icon size={18} className={col.color} />
                <h3 className="font-medium text-white">{col.title}</h3>
                <span className="bg-gray-800 text-gray-400 text-xs px-2 py-1 rounded-full ml-auto border border-gray-700">
                  {tasks.filter(t => t.status === col.id).length}
                </span>
              </div>

              <div className="space-y-3">
                {tasks.filter(t => t.status === col.id).map(task => {
                  const assignee = team.find(t => t.id === task.assigneeId);
                  return (
                    <div key={task.id} className="bg-gray-800 p-4 rounded-lg border border-gray-700 shadow-sm hover:border-gray-600 transition-colors">
                      <div className="flex justify-between items-start mb-2">
                        <p className="text-sm text-white font-medium pr-4">{task.title}</p>
                        {/* Only Admins can delete tasks */}
                        {myProfile.systemRole === 'Admin' && (
                          <button onClick={() => deleteTask(task.id)} className="text-gray-500 hover:text-red-400 transition-colors">
                            &times;
                          </button>
                        )}
                      </div>
                      <p className="text-xs text-gray-400 mb-4">{projects.find(p => p.id === task.projectId)?.name}</p>
                      
                      <div className="flex items-center justify-between mt-4 pt-4 border-t border-gray-700/50">
                        <div className="flex items-center gap-2">
                          <div className={`w-6 h-6 rounded-full ${assignee?.color || 'bg-gray-600'} flex items-center justify-center text-[10px] font-bold text-white`} title={assignee?.name}>
                            {assignee?.initials || '?'}
                          </div>
                        </div>
                        
                        <select 
                          value={task.status}
                          onChange={(e) => updateTaskStatus(task.id, e.target.value)}
                          className="bg-gray-900 text-xs text-gray-300 border border-gray-700 rounded px-2 py-1 outline-none focus:border-indigo-500 cursor-pointer"
                        >
                          <option value="todo">To Do</option>
                          <option value="in-progress">In Progress</option>
                          <option value="done">Done</option>
                        </select>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      </div>
    );
  };

  const TeamView = () => (
    <div>
      <h2 className="text-2xl font-semibold text-white mb-6">Team Directory</h2>
      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {team.map(member => (
          <div key={member.id} className="bg-gray-800 p-6 rounded-xl border border-gray-700 flex flex-col items-center text-center shadow-sm relative">
            {member.systemRole === 'Admin' && (
              <span className="absolute top-4 right-4 text-[10px] uppercase font-bold tracking-wider text-indigo-400 bg-indigo-500/10 px-2 py-1 rounded">
                Admin
              </span>
            )}
            <div className={`w-16 h-16 rounded-full ${member.color} flex items-center justify-center text-xl font-bold text-white mb-4 shadow-inner`}>
              {member.initials}
            </div>
            <h3 className="text-white font-medium text-lg">{member.name}</h3>
            <p className="text-gray-400 text-sm mb-4">{member.role}</p>
            
            <div className="w-full bg-gray-900 rounded-lg p-3 mt-auto border border-gray-700/50">
              <p className="text-xs text-gray-400 mb-1">Assigned Tasks</p>
              <p className="text-lg text-white font-semibold">
                {tasks.filter(t => t.assigneeId === member.id).length}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  );

  const ProfileView = () => (
    <div className="max-w-2xl">
      <h2 className="text-2xl font-semibold text-white mb-6">My Profile</h2>
      <div className="bg-gray-800 rounded-xl border border-gray-700 p-8 shadow-sm">
        <div className="flex items-center gap-6 mb-8">
          <div className={`w-24 h-24 rounded-full ${myProfile.color} flex items-center justify-center text-3xl font-bold text-white shadow-inner`}>
            {myProfile.initials}
          </div>
          <div>
            <h3 className="text-2xl font-bold text-white">{myProfile.name}</h3>
            <p className="text-indigo-400 font-medium">{myProfile.role}</p>
            <span className="inline-block mt-2 bg-gray-700 text-gray-300 text-xs px-2 py-1 rounded">
              System Role: {myProfile.systemRole}
            </span>
          </div>
        </div>
        
        <div className="space-y-4 pt-6 border-t border-gray-700">
          <div>
            <p className="text-sm text-gray-400">Company</p>
            <p className="text-white font-medium">{company.name}</p>
          </div>
          <div>
            <p className="text-sm text-gray-400">Total Tasks Completed by You</p>
            <p className="text-white font-medium">{tasks.filter(t => t.assigneeId === user.uid && t.status === 'done').length}</p>
          </div>
        </div>
      </div>
    </div>
  );

  // --- MAIN RENDER ---
  return (
    <div className="flex h-screen bg-gray-950 font-sans selection:bg-indigo-500/30">
      <Sidebar />
      
      <main className="flex-1 overflow-y-auto p-8">
        <div className="max-w-6xl mx-auto">
          {activeTab === 'dashboard' && <DashboardView />}
          {activeTab === 'projects' && (
            <div className="space-y-6">
              <h2 className="text-2xl font-semibold text-white">Client Projects</h2>
              <div className="grid grid-cols-1 gap-4">
                {projects.map(project => (
                  <div key={project.id} className="bg-gray-800 p-6 rounded-xl border border-gray-700 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 shadow-sm">
                    <div>
                      <h3 className="text-lg font-medium text-white">{project.name}</h3>
                      <p className="text-gray-400 text-sm mt-1">Client: {project.client} &nbsp;•&nbsp; Deadline: {project.deadline}</p>
                    </div>
                    <button
                      onClick={() => generateTasksForProject(project.id, project.name)}
                      disabled={isGeneratingTasks === project.id}
                      className="bg-indigo-600/20 text-indigo-400 hover:bg-indigo-600 hover:text-white px-4 py-2 rounded-lg text-sm font-medium flex items-center gap-2 transition-colors disabled:opacity-50 border border-indigo-500/30"
                    >
                      <Sparkles size={16} />
                      {isGeneratingTasks === project.id ? 'Generating Tasks...' : '✨ Auto-Tasks'}
                    </button>
                  </div>
                ))}
                {projects.length === 0 && (
                  <div className="bg-gray-800 rounded-xl border border-gray-700 p-6 text-center">
                    <Briefcase className="mx-auto text-gray-500 mb-3" size={32} />
                    <p className="text-gray-300">No active projects found.</p>
                  </div>
                )}
              </div>
            </div>
          )}
          {activeTab === 'tasks' && <TaskBoard />}
          {activeTab === 'team' && <TeamView />}
          {activeTab === 'profile' && <ProfileView />}
        </div>
      </main>

      {/* NEW TASK MODAL */}
      {isModalOpen && (
        <div className="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4 backdrop-blur-sm">
          <div className="bg-gray-900 rounded-xl border border-gray-700 w-full max-w-md p-6 shadow-2xl">
            <h3 className="text-xl font-semibold text-white mb-4">Create New Task</h3>
            <form onSubmit={handleAddTask} className="space-y-4">
              <div>
                <label className="block text-sm font-medium text-gray-400 mb-1">Task Title</label>
                <input 
                  type="text" required value={newTask.title}
                  onChange={(e) => setNewTask({...newTask, title: e.target.value})}
                  className="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 text-white outline-none focus:border-indigo-500"
                  placeholder="e.g. Design Logo"
                />
              </div>
              <div>
                <label className="block text-sm font-medium text-gray-400 mb-1">Project</label>
                <select 
                  required value={newTask.projectId}
                  onChange={(e) => setNewTask({...newTask, projectId: e.target.value})}
                  className="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 text-white outline-none focus:border-indigo-500"
                >
                  <option value="" disabled>Select a project</option>
                  {projects.map(p => <option key={p.id} value={p.id}>{p.name}</option>)}
                </select>
              </div>
              <div>
                <label className="block text-sm font-medium text-gray-400 mb-1">Assign To</label>
                <select 
                  required value={newTask.assigneeId}
                  onChange={(e) => setNewTask({...newTask, assigneeId: e.target.value})}
                  className="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 text-white outline-none focus:border-indigo-500"
                >
                  <option value="" disabled>Select a team member</option>
                  {team.map(t => <option key={t.id} value={t.id}>{t.name} ({t.role})</option>)}
                </select>
              </div>
              <div className="flex justify-end gap-3 mt-6 pt-4 border-t border-gray-800">
                <button type="button" onClick={() => setIsModalOpen(false)} className="px-4 py-2 text-sm font-medium text-gray-400 hover:text-white">Cancel</button>
                <button type="submit" className="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">Save Task</button>
              </div>
            </form>
          </div>
        </div>
      )}
    </div>
  );
}
